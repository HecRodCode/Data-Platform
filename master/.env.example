# --- Database ---
POSTGRES_USER=<your_user>
POSTGRES_PASSWORD=<your_password>
POSTGRES_DB=<your_databse>

# --- Airflow Core ---
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=<your_fernet_key>
AIRFLOW__CORE__LOAD_EXAMPLES=<false/true>

# --- Conexiones ---
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<your_user>:<your_password>@<host>:5432/<your_databse>
AIRFLOW__CELERY__RESULT_BACKEND=postgresql+psycopg2://<your_user>:<your_password>@<host>:5432/<your_databse>

# --- Broker (RabbitMQ) ---
RABBITMQ_DEFAULT_USER=<your_user>
RABBITMQ_DEFAULT_PASS=<your_password>
AIRFLOW__CELERY__BROKER_URL=amqp://<your_user>:<your_password>@rabbitmq:5672/

# --- Credenciales UI ---
AIRFLOW__WEBSERVER__ADMIN_USER=<your_user>
AIRFLOW__WEBSERVER__ADMIN_PASSWORD=<your_password>